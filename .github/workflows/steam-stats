name: Steam Stats

on:
  push:
    branches: [main]
  workflow_dispatch:
  schedule:
    # Runs every Monday at 12AM IST (UTC+5:30)
    - cron: "30 18 * * 0"

jobs:
  steam-stats:
    name: Steam Stats
    runs-on: ubuntu-latest
    steps:
      - uses: nicconike/steam-stats@master
        with:
          STEAM_API_KEY: ${{ secrets.STEAM_API_KEY }} # Steam API key env var
          STEAM_ID: ${{ secrets.STEAM_ID }} # Steam ID env var
          STEAM_CUSTOM_ID: ${{ secrets.STEAM_CUSTOM_ID }} # Custom ID env var
          WORKSHOP_STATS: True # Optional
          LOG_SCALE: True # Optional
